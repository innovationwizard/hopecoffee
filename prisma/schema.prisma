// ============================================================================
// HOPE COFFEE — Prisma Schema
// Coffee Export Contract & Margin Management System
// ============================================================================
// Domain: Guatemalan specialty coffee export operations
// Entities model the full lifecycle: purchase → processing → export → billing
// All monetary values stored as Decimal for financial precision
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// AUTH & ACCESS CONTROL
// ============================================================================

enum UserRole {
  MASTER        // Developer / system owner — unrestricted
  GERENCIA      // CEO executive oversight — read-only dashboards with full drill-down
  FINANCIERO    // CFO active role — exchange rates, export costs, contract financial terms
  COMPRAS       // Sourcing & purchasing — OC lifecycle, supplier management, receipt assignment
  VENTAS        // Sales manager — contract lifecycle, CRM, lot allocation, shipment coordination
  LAB           // Quality lab — cupping, samples, yield adjustments, milling orders
  ANALISIS      // Financial analyst — cost control, margin analysis, reporting
  CONTABILIDAD  // Accounting link — payments, journal entries, fiscal documents
  LOGISTICA     // Future: shipment logistics (Evelyn)
  LAB_ASISTENTE // Future: lab data entry and field QC (Douglas)
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs       AuditLog[]
  roleAssignments UserRoleAssignment[]

  @@map("users")
}

model UserRoleAssignment {
  id         String   @id @default(cuid())
  userId     String
  role       UserRole
  assignedBy String?  // userId who granted this role (null = system/seed)
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@map("user_role_assignments")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // CREATE, UPDATE, DELETE, STATUS_CHANGE, PRICE_FIX
  entity     String   // Contract, Shipment, PurchaseOrder, etc.
  entityId   String
  oldValue   Json?    // Snapshot before change
  newValue   Json?    // Snapshot after change
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ============================================================================
// SYSTEM CONFIGURATION
// ============================================================================

model ExchangeRate {
  id        String   @id @default(cuid())
  rate      Decimal  @db.Decimal(10, 4) // e.g., 7.6500
  validFrom DateTime
  validTo   DateTime?
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())

  @@index([validFrom, validTo])
  @@map("exchange_rates")
}

model ExportCostConfig {
  id                String   @id @default(cuid())
  name              String   // e.g., "Default 2026", "Organico Premium"
  gastosPerSaco     Decimal  @db.Decimal(10, 2) // Export cost per saco (20-23)
  trillaPerQQ       Decimal  @db.Decimal(10, 2) // Milling cost per quintal
  sacoYute          Decimal  @db.Decimal(10, 2)
  estampado         Decimal  @db.Decimal(10, 2)
  bolsaGrainPro     Decimal  @db.Decimal(10, 2)
  fitoSanitario     Decimal  @db.Decimal(10, 2)
  impuestoAnacafe1  Decimal  @db.Decimal(10, 2)
  impuestoAnacafe2  Decimal  @db.Decimal(10, 2)
  inspeccionOirsa   Decimal  @db.Decimal(10, 2)
  fumigacion        Decimal  @db.Decimal(10, 2)
  emisionDocumento  Decimal  @db.Decimal(10, 2)
  fletePuerto       Decimal  @db.Decimal(10, 2)
  seguro            Decimal  @db.Decimal(10, 2)
  custodio          Decimal  @db.Decimal(10, 2)
  agenteAduanal     Decimal  @db.Decimal(10, 2)
  comisionExportadorOrganico Decimal @db.Decimal(10, 2) @default(0)
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shipments Shipment[]
  contracts Contract[] @relation("ContractExportCostConfig")

  @@map("export_cost_configs")
}

// ============================================================================
// COMMERCIAL ENTITIES
// ============================================================================

model Client {
  id        String   @id @default(cuid())
  name      String   @unique // Serengetti, Swiss Water, Opal, Onyx, Atlas, Stonex
  code      String   @unique // SER, SWP, OPL, ONX, ATL, STX
  country   String?
  contact   String?
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts      Contract[]
  shipmentParties ShipmentParty[]

  @@map("clients")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique // K-Finos, José David Guerra, Walco
  code      String   @unique
  contact   String?
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders   PurchaseOrder[]
  accountEntries   SupplierAccountEntry[]
  lots             Lot[]

  @@map("suppliers")
}

// ============================================================================
// CONTRACT MANAGEMENT (Core Domain)
// ============================================================================

enum ContractStatus {
  NEGOCIACION  // Under negotiation
  CONFIRMADO   // Confirmed, terms agreed
  FIJADO       // Price fixed (bolsa locked)
  NO_FIJADO    // Confirmed but price floating
  EMBARCADO    // Shipped
  LIQUIDADO    // Fully settled/paid
  CANCELADO    // Cancelled
}

enum CoffeeRegion {
  SANTA_ROSA
  HUEHUETENANGO
  ORGANICO
  DANILANDIA
  SANTA_ISABEL
  OTHER
}

enum POStatus {
  PENDIENTE
  RECIBIDO
  LIQUIDADO
}

enum ShipmentStatus {
  PREPARACION  // Being assembled
  EMBARCADO    // Shipped
  LIQUIDADO    // Settled
}

enum ExportingEntity {
  EXPORTADORA       // Main export company (business_rules §1.1, §1.15)
  FINCA_DANILANDIA  // Farm entity
  STOCK_LOCK        // Buy FOB / sell FOB, no materia prima (§1.2)
}

enum PosicionBolsa {
  MAR // Marzo
  MAY // Mayo
  JUL // Julio
  SEP // Septiembre
  DEC // Diciembre
}

enum FacilityType {
  BENEFICIO  // Dry mill processing
  BODEGA     // Warehouse/storage
  PATIO      // Drying yard
}

enum LotStage {
  PERGAMINO_BODEGA  // Received, in warehouse
  EN_PROCESO        // Being milled
  ORO_EXPORTABLE    // Gold coffee ready for export
  EXPORTADO         // Shipped in a container
  SUBPRODUCTO       // By-product (segunda, cascarilla)
}

enum MillingOrderStatus {
  PENDIENTE    // Scheduled
  EN_PROCESO   // In progress
  COMPLETADO   // Finished
}

enum MillingOutputType {
  ORO_EXPORTABLE  // Exportable green/gold coffee
  SEGUNDA         // Second-grade by-product
  CASCARILLA      // Husk by-product
  MERMA           // Loss/shrinkage
}

enum ShipmentPartyRole {
  BROKER    // Trade intermediary
  IMPORTER  // Importing company
  BUYER     // End buyer
}

enum YieldAdjustmentStatus {
  PENDIENTE  // Awaiting COO review
  APLICADO   // Applied to supplier payment
  RECHAZADO  // Rejected by COO
}

model Contract {
  id                  String          @id @default(cuid())
  contractNumber      String          @unique // P40129, P40028, etc. — CFO's reference
  officialCorrelative String?         @unique // Auto: HC-{YEAR}-{SEQ} — canonical company-wide ID
  cooContractName     String?         // COO's field reference (e.g., "Serengeti Enero EP")
  clientId            String
  shipmentId          String?
  status              ContractStatus  @default(NEGOCIACION)
  regions             CoffeeRegion[]  // Can span multiple regions

  // Coffee specs
  puntaje         Int             // Cupping score: 81-85+
  sacos69kg       Decimal         @db.Decimal(10, 2) // Bags at 69kg
  sacos46kg       Decimal         @db.Decimal(10, 2) // Calculated: sacos69kg × 1.5

  // Exporting entity (business_rules §1.1, §1.15)
  exportingEntity ExportingEntity @default(EXPORTADORA)

  // Pricing (USD per 100lb sack)
  precioBolsa     Decimal?        @db.Decimal(10, 2) // NY C-market or fixed price
  diferencial     Decimal?        @db.Decimal(10, 2) // Differential above/below bolsa
  precioBolsaDif  Decimal?        @db.Decimal(10, 2) // Computed: bolsa + diferencial

  // Manual facturación override — for exceptional legal-document cases
  // where the signed contract deviates from the default kg formula.
  // When set, calculateContract uses this value verbatim for O.
  // overrideReason is required whenever facturacionKgsOverride is non-null
  // and is surfaced in the UI so exceptions are never silently invisible.
  facturacionKgsOverride Decimal? @db.Decimal(14, 2)
  overrideReason         String?

  // Billing & commissions
  comisionCompra  Decimal?        @db.Decimal(10, 2) // 1.50 USD/quintal (buy)
  comisionVenta   Decimal?        @db.Decimal(10, 2) // 1.50 USD/quintal (sell)
  montoCredito    Decimal?        @db.Decimal(14, 2) // Credit amount in GTQ for financial cost
  cfTasaAnual     Decimal?        @db.Decimal(6, 4)  // Annual interest rate (default 0.08)
  cfMeses         Int?                                // Financing months (default 2)

  // ISR — Impuesto Sobre la Renta (subject to fiscal incentives per contract)
  isrRate         Decimal?        @db.Decimal(6, 4)  // Percentage as decimal (e.g. 0.06 = 6%)
  isrAmount       Decimal?        @db.Decimal(14, 2) // Fixed amount override in QTZ (takes precedence over rate)

  // Harvest year
  cosecha         String?         // "25/26", "26/27"

  // Position & timing
  posicionBolsa   PosicionBolsa?  // ICE futures month (min 2 months ahead of embarque)
  posicionNY      DateTime?       // NY futures position date
  fechaEmbarque   DateTime?       // Shipment date
  lote            String?         // Lot description: "Organico", "Santa Rosa", "Huehue"

  // Computed billing fields (stored for performance, recalculated on change)
  facturacionLbs  Decimal?        @db.Decimal(14, 2) // Billing in pounds
  facturacionKgs  Decimal?        @db.Decimal(14, 2) // Billing in kilos (with conversion)
  gastosExport    Decimal?        @db.Decimal(14, 2) // Export expenses
  utilidadSinGE   Decimal?        @db.Decimal(14, 2) // Profit before export expenses
  costoFinanciero Decimal?        @db.Decimal(14, 2) // Financial cost
  utilidadSinCF   Decimal?        @db.Decimal(14, 2) // Profit before financial cost
  tipoCambio      Decimal?        @db.Decimal(10, 4) // Exchange rate at contract
  totalPagoQTZ    Decimal?        @db.Decimal(14, 2) // Total payment in Quetzales

  // Inventory & subproducto inputs
  precioPromedioInv   Decimal?  @db.Decimal(10, 2) // Avg inventory cost per QQ
  subproductos        Decimal?  @db.Decimal(10, 2) // Subproducto qty (oro)
  precioSubproducto   Decimal?  @db.Decimal(10, 2) // Subproducto unit price

  // Export cost breakdown (per-saco components, persisted at contract creation)
  gastosPerSaco               Decimal?  @db.Decimal(10, 2)
  exportTrillaPerQQ           Decimal?  @db.Decimal(10, 2)
  exportSacoYute              Decimal?  @db.Decimal(10, 2)
  exportEstampado             Decimal?  @db.Decimal(10, 2)
  exportBolsaGrainPro         Decimal?  @db.Decimal(10, 2)
  exportFitoSanitario         Decimal?  @db.Decimal(10, 2)
  exportImpuestoAnacafe1      Decimal?  @db.Decimal(10, 2)
  exportImpuestoAnacafe2      Decimal?  @db.Decimal(10, 2)
  exportInspeccionOirsa       Decimal?  @db.Decimal(10, 2)
  exportFumigacion            Decimal?  @db.Decimal(10, 2)
  exportEmisionDocumento      Decimal?  @db.Decimal(10, 2)
  exportFletePuerto           Decimal?  @db.Decimal(10, 2)
  exportSeguro                Decimal?  @db.Decimal(10, 2)
  exportCustodio              Decimal?  @db.Decimal(10, 2)
  exportAgenteAduanal         Decimal?  @db.Decimal(10, 2)
  exportComisionOrganico      Decimal?  @db.Decimal(10, 2)

  notes           String?
  computedAt      DateTime?       // Set by computeContractFields(), staleness = updatedAt > computedAt
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Snapshot references
  exportCostConfigId String?

  client           Client            @relation(fields: [clientId], references: [id])
  shipment         Shipment?         @relation(fields: [shipmentId], references: [id])
  exportCostConfig ExportCostConfig? @relation("ContractExportCostConfig", fields: [exportCostConfigId], references: [id])

  materiaPrimaAllocations MateriaPrimaAllocation[]
  priceSnapshots          ContractPriceSnapshot[]
  lotAllocations          ContractLotAllocation[]

  @@index([clientId])
  @@index([shipmentId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([fechaEmbarque])
  @@map("contracts")
}

// ============================================================================
// SHIPMENT MANAGEMENT (Monthly Container Grouping)
// ============================================================================

model Shipment {
  id                  String   @id @default(cuid())
  name                String   // "Enero 2026", "Febrero 2026", etc.
  month               Int      // 1-12
  year                Int
  status              ShipmentStatus @default(PREPARACION)
  numContainers       Int      // Number of containers
  regions             String?  // Descriptive: "Organico/Santa Rosa/Huehue"
  posicionDate        DateTime?
  embarqueDate        DateTime?
  exportCostConfigId  String?
  gastosPerSaco       Decimal? @db.Decimal(10, 2) // Override per-saco cost

  // Aggregated computed fields
  totalSacos69        Decimal? @db.Decimal(10, 2)
  totalSacos46        Decimal? @db.Decimal(10, 2)
  totalFacturacionLbs Decimal? @db.Decimal(14, 2)
  totalFacturacionKgs Decimal? @db.Decimal(14, 2)
  totalGastosExport   Decimal? @db.Decimal(14, 2)
  totalUtilidadSinGE  Decimal? @db.Decimal(14, 2)
  totalCostoFinanc    Decimal? @db.Decimal(14, 2)
  totalUtilidadSinCF  Decimal? @db.Decimal(14, 2)
  totalPagoQTZ        Decimal? @db.Decimal(14, 2)

  // P&L aggregates
  totalFacturacionQTZ Decimal? @db.Decimal(14, 2) // facturacionKgs × tipoCambio per contract
  totalMateriaPrima   Decimal? @db.Decimal(14, 2)
  totalISR            Decimal? @db.Decimal(14, 2) // ISR retention on materia prima (6%)
  totalComision       Decimal? @db.Decimal(14, 2) // Comision in QTZ (USD × tipoCambio per contract)
  totalSubproducto    Decimal? @db.Decimal(14, 2)
  utilidadBruta       Decimal? @db.Decimal(14, 2)
  margenBruto         Decimal? @db.Decimal(8, 6) // Percentage as decimal

  notes               String?
  aggregatedAt        DateTime? // Set by recalculateShipment(), staleness = updatedAt > aggregatedAt
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  exportCostConfig ExportCostConfig? @relation(fields: [exportCostConfigId], references: [id])
  contracts        Contract[]
  containers       Container[]
  materiaPrima     MateriaPrima[]
  subproductos     Subproducto[]
  parties          ShipmentParty[]

  @@unique([month, year, name])
  @@index([year, month])
  @@map("shipments")
}

// ============================================================================
// RAW MATERIAL & COST TRACKING
// ============================================================================

model MateriaPrima {
  id           String   @id @default(cuid())
  shipmentId   String
  supplierId   String?
  supplierNote String?  // "Comprado / José David", "Comprado / Kfinos", "NO COMPRADO"
  isPurchased  Boolean  @default(false)

  punteo       Int               // Cupping score
  oro          Decimal           @db.Decimal(10, 2) // Gold coffee qty (sacos 46kg)
  rendimiento  Decimal           @db.Decimal(8, 6)  // Yield: typically 1.32
  pergamino    Decimal           @db.Decimal(10, 2) // Parchment coffee qty
  precioPromQ  Decimal           @db.Decimal(10, 2) // Average price in Quetzales
  totalMP      Decimal           @db.Decimal(14, 2) // pergamino × precioPromQ

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  shipment    Shipment                @relation(fields: [shipmentId], references: [id])
  allocations MateriaPrimaAllocation[]

  @@index([shipmentId])
  @@map("materia_prima")
}

model MateriaPrimaAllocation {
  id                  String   @id @default(cuid())
  materiaPrimaId      String
  contractId          String
  quintalesAllocated  Decimal? @db.Decimal(10, 2) // null = full allocation (backward compat)

  materiaPrima MateriaPrima @relation(fields: [materiaPrimaId], references: [id])
  contract     Contract     @relation(fields: [contractId], references: [id])

  @@unique([materiaPrimaId, contractId])
  @@map("materia_prima_allocations")
}

model Subproducto {
  id            String  @id @default(cuid())
  shipmentId    String
  contenedores  Decimal @db.Decimal(10, 4) // Can be fractional (e.g., 0.6545)
  oroPerCont    Decimal @db.Decimal(10, 2) // Typically 25
  totalOro      Decimal @db.Decimal(10, 2) // contenedores × oroPerCont
  precioSinIVA  Decimal @db.Decimal(10, 2) // Typically 2000
  totalPerga    Decimal @db.Decimal(14, 2) // totalOro × precioSinIVA

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
  @@map("subproductos")
}

// ============================================================================
// PURCHASE ORDERS & INVENTORY
// ============================================================================

model PurchaseOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique // OC-2526-01, OC-2526-02
  supplierId      String
  date            DateTime
  status          POStatus @default(PENDIENTE)
  cosecha         String?  // "25/26", "26/27"

  // Pergamino purchase
  quintalesPerg   Decimal  @db.Decimal(10, 2)
  precioPerg      Decimal  @db.Decimal(10, 2) // Price per quintal
  totalCafe       Decimal  @db.Decimal(14, 2) // quintales × precio

  // Logistics costs
  fletePorQQ      Decimal  @db.Decimal(10, 2)
  totalFlete      Decimal  @db.Decimal(14, 2)
  seguridad       Decimal  @db.Decimal(10, 2)
  seguro          Decimal  @db.Decimal(10, 2)
  cadena          Decimal  @db.Decimal(10, 2) @default(0)
  cargas          Decimal  @db.Decimal(10, 2) @default(0)
  descargas       Decimal  @db.Decimal(10, 2) @default(0)

  // Computed
  costoTotalAccum Decimal  @db.Decimal(14, 2) // All-in cost
  precioPromedio  Decimal  @db.Decimal(10, 4) // Weighted average price

  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([date])
  @@map("purchase_orders")
}

// ============================================================================
// SUPPLIER ACCOUNT TRACKING (Estado de Cuenta)
// ============================================================================

model SupplierAccountEntry {
  id           String   @id @default(cuid())
  supplierId   String
  orderCode    String   // OC4, OC5, OC6, OC8
  ingresoNum   Int      // Entry/receipt number (568, 569, etc.)
  date         DateTime
  pergamino    Decimal  @db.Decimal(10, 2) // Weight in qq
  precio       Decimal  @db.Decimal(10, 2) // Price per qq
  total        Decimal  @db.Decimal(14, 2) // pergamino × precio
  lotId        String?  // Links receipt to created lot
  facilityId   String?  // Receiving facility
  qualityGrade String?  // Preliminary grade before cupping
  createdAt    DateTime @default(now())

  supplier Supplier  @relation(fields: [supplierId], references: [id])
  lot      Lot?      @relation(fields: [lotId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([supplierId, orderCode])
  @@index([date])
  @@map("supplier_account_entries")
}

// ============================================================================
// FARM FINANCING (Brisas, San Emiliano)
// ============================================================================

model Farm {
  id               String  @id @default(cuid())
  name             String  @unique // "BRISAS", "SAN EMILIANO"
  totalQuetzales   Decimal @db.Decimal(14, 2)
  tipoCambio       Decimal @db.Decimal(10, 4)
  totalUSD         Decimal @db.Decimal(14, 2) // totalQuetzales / tipoCambio
  porcentaje       Decimal @db.Decimal(8, 6)  // Weight percentage
  aumentoPorcentaje Decimal @db.Decimal(8, 4) // 0.20 = 20%
  nuevoTotal       Decimal @db.Decimal(14, 2) // totalUSD × (1 + aumento)
  porcentajePrest  Decimal @db.Decimal(6, 4)  // Loan percentage (0.70)
  totalPrestamo    Decimal @db.Decimal(14, 2) // nuevoTotal × porcentajePrest

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("farms")
}

// ============================================================================
// CONTAINER TRACKING (Per-container logistics)
// ============================================================================

model Container {
  id            String    @id @default(cuid())
  shipmentId    String
  containerNum  String?   // MSKU1234567
  blNumber      String?   // Bill of Lading
  sealNumber    String?
  weightKg      Decimal?  @db.Decimal(10, 2)
  vessel        String?
  port          String?
  eta           DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shipment      Shipment       @relation(fields: [shipmentId], references: [id])
  containerLots ContainerLot[]

  @@index([shipmentId])
  @@map("containers")
}

// ============================================================================
// CONTRACT PRICE HISTORY (Audit-grade price snapshots)
// ============================================================================

model ContractPriceSnapshot {
  id            String          @id @default(cuid())
  contractId    String
  precioBolsa   Decimal?        @db.Decimal(10, 2)
  diferencial   Decimal?        @db.Decimal(10, 2)
  tipoCambio    Decimal?        @db.Decimal(10, 4)
  posicionBolsa PosicionBolsa?
  status        ContractStatus
  triggeredBy   String?         // userId
  reason        String?         // "price_update", "status_change", "manual"
  snapshotAt    DateTime        @default(now())

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId, snapshotAt])
  @@map("contract_price_snapshots")
}

// ============================================================================
// FACILITY MANAGEMENT (Physical locations within La Joya)
// ============================================================================

model Facility {
  id        String       @id @default(cuid())
  name      String       @unique // "Beneficio", "Bodega", "Patio"
  code      String       @unique // "BEN", "BOD", "PAT"
  type      FacilityType
  capacity  Decimal?     @db.Decimal(10, 2) // Max QQ capacity (nullable)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  lots                  Lot[]
  millingOrders         MillingOrder[]
  supplierAccountEntries SupplierAccountEntry[]

  @@map("facilities")
}

// ============================================================================
// LOT TRACKING (Trackable unit of coffee through processing)
// ============================================================================

model Lot {
  id                   String    @id @default(cuid())
  lotNumber            String    @unique // Auto: LOT-{YEAR}-{SEQ}
  supplierId           String?
  facilityId           String?
  purchaseOrderId      String?
  stage                LotStage  @default(PERGAMINO_BODEGA)
  quantityQQ           Decimal   @db.Decimal(10, 2) // Current quantity in quintales
  qualityGrade         String?   // Preliminary grade
  cuppingScore         Decimal?  @db.Decimal(5, 2)  // SCA total score (set after cupping)
  receptionDate        DateTime?
  sourceAccountEntryId String?   // Links to SupplierAccountEntry
  contractedYield      Decimal?  @db.Decimal(8, 6)  // Expected rendimiento from PO
  actualYield          Decimal?  @db.Decimal(8, 6)  // Measured rendimiento from cupping
  costPerQQ            Decimal?  @db.Decimal(10, 2) // For cost-based inventory valuation
  parentLotId          String?   // Traceability: which lot was this derived from
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  supplier     Supplier?  @relation(fields: [supplierId], references: [id])
  facility     Facility?  @relation(fields: [facilityId], references: [id])
  parentLot    Lot?       @relation("LotLineage", fields: [parentLotId], references: [id])
  childLots    Lot[]      @relation("LotLineage")

  cuppingRecords         CuppingRecord[]
  millingInputs          MillingInput[]
  millingOutputs         MillingOutput[]
  contractLotAllocations ContractLotAllocation[]
  containerLots          ContainerLot[]
  sourceAccountEntries   SupplierAccountEntry[]

  @@index([supplierId])
  @@index([facilityId])
  @@index([stage])
  @@index([receptionDate])
  @@map("lots")
}

// ============================================================================
// QUALITY LAB (SCA Cupping Protocol)
// ============================================================================

model CuppingRecord {
  id              String   @id @default(cuid())
  lotId           String
  catadorUserId   String?  // Who performed the cupping
  date            DateTime

  // SCA 10-attribute scores (each 6.00-10.00)
  fragrance       Decimal  @db.Decimal(4, 2)
  flavor          Decimal  @db.Decimal(4, 2)
  aftertaste      Decimal  @db.Decimal(4, 2)
  acidity         Decimal  @db.Decimal(4, 2)
  body            Decimal  @db.Decimal(4, 2)
  balance         Decimal  @db.Decimal(4, 2)
  uniformity      Decimal  @db.Decimal(4, 2)
  cleanCup        Decimal  @db.Decimal(4, 2)
  sweetness       Decimal  @db.Decimal(4, 2)
  overall         Decimal  @db.Decimal(4, 2)
  totalScore      Decimal  @db.Decimal(5, 2)  // Sum of 10 attributes

  // Physical analysis
  moisturePercent Decimal? @db.Decimal(4, 2)  // Target 10.5-12.5%
  defectCount     Int?                         // Per 350g sample
  screenSize      String?                      // e.g., "15/16", "17/18"
  waterActivity   Decimal? @db.Decimal(3, 2)  // Target <0.65 aw

  yieldMeasured   Decimal? @db.Decimal(8, 6)  // Rendimiento real
  purchaseOrderId String?  // For reconciliation with PO
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lot              Lot               @relation(fields: [lotId], references: [id])
  yieldAdjustments YieldAdjustment[]

  @@index([lotId])
  @@index([date])
  @@map("cupping_records")
}

model YieldAdjustment {
  id                       String                @id @default(cuid())
  cuppingRecordId          String
  supplierAccountEntryId   String?
  contractedYield          Decimal               @db.Decimal(8, 6)
  actualYield              Decimal               @db.Decimal(8, 6)
  toleranceApplied         Decimal               @db.Decimal(8, 6) // Default 0.01
  priceAdjustmentPerQQ     Decimal               @db.Decimal(10, 2)
  totalAdjustment          Decimal               @db.Decimal(14, 2)
  status                   YieldAdjustmentStatus @default(PENDIENTE)
  appliedAt                DateTime?
  appliedByUserId          String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  cuppingRecord CuppingRecord @relation(fields: [cuppingRecordId], references: [id])

  @@index([status])
  @@index([cuppingRecordId])
  @@map("yield_adjustments")
}

model YieldToleranceConfig {
  id              String   @id @default(cuid())
  toleranceValue  Decimal  @db.Decimal(8, 6) @default(0.01) // Default +/- 0.01
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  @@map("yield_tolerance_config")
}

// ============================================================================
// MILLING (Tría — Inventory Transformation)
// ============================================================================

model MillingOrder {
  id              String             @id @default(cuid())
  orderNumber     String             @unique // Auto: TRIA-{YEAR}-{SEQ}
  facilityId      String?
  date            DateTime
  operatorUserId  String?
  status          MillingOrderStatus @default(PENDIENTE)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  facility Facility? @relation(fields: [facilityId], references: [id])
  inputs   MillingInput[]
  outputs  MillingOutput[]

  @@index([date])
  @@index([status])
  @@map("milling_orders")
}

model MillingInput {
  id             String  @id @default(cuid())
  millingOrderId String
  lotId          String
  quantityQQ     Decimal @db.Decimal(10, 2)

  millingOrder MillingOrder @relation(fields: [millingOrderId], references: [id], onDelete: Cascade)
  lot          Lot          @relation(fields: [lotId], references: [id])

  @@index([millingOrderId])
  @@map("milling_inputs")
}

model MillingOutput {
  id             String           @id @default(cuid())
  millingOrderId String
  lotId          String?          // New lot created for output (null for merma)
  quantityQQ     Decimal          @db.Decimal(10, 2)
  outputType     MillingOutputType
  qualityGrade   String?
  costPerQQ      Decimal?         @db.Decimal(10, 2) // Allocated from inputs

  millingOrder MillingOrder @relation(fields: [millingOrderId], references: [id], onDelete: Cascade)
  lot          Lot?         @relation(fields: [lotId], references: [id])

  @@index([millingOrderId])
  @@index([outputType])
  @@map("milling_outputs")
}

// ============================================================================
// SHIPMENT COMMERCIAL PARTIES (Per-shipment client roles)
// ============================================================================

model ShipmentParty {
  id         String           @id @default(cuid())
  shipmentId String
  clientId   String
  role       ShipmentPartyRole
  notes      String?
  createdAt  DateTime         @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id])

  @@unique([shipmentId, clientId, role])
  @@index([shipmentId])
  @@map("shipment_parties")
}

// ============================================================================
// CONTRACT-TO-LOT ALLOCATION (Oro lots assigned to sales contracts)
// ============================================================================

model ContractLotAllocation {
  id         String  @id @default(cuid())
  contractId String
  lotId      String
  quantityQQ Decimal @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id])
  lot      Lot      @relation(fields: [lotId], references: [id])

  @@unique([contractId, lotId])
  @@map("contract_lot_allocations")
}

// ============================================================================
// CONTAINER-TO-LOT TRACKING (Per-lot export tracking)
// ============================================================================

model ContainerLot {
  id          String  @id @default(cuid())
  containerId String
  lotId       String
  quantityQQ  Decimal @db.Decimal(10, 2)

  container Container @relation(fields: [containerId], references: [id], onDelete: Cascade)
  lot       Lot       @relation(fields: [lotId], references: [id])

  @@unique([containerId, lotId])
  @@map("container_lots")
}
